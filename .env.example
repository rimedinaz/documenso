# Documenso Standalone Configuration

# Database Configuration
POSTGRES_USER=documenso
POSTGRES_PASSWORD=changeme
POSTGRES_DB=documenso
POSTGRES_PORT=5432

# Application Configuration
PORT=3000
NEXT_PUBLIC_WEBAPP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET= # Generated automatically by init.sh if empty

# Encryption Keys (32 chars)
NEXT_PRIVATE_ENCRYPTION_KEY= # Generated automatically by init.sh if empty
NEXT_PRIVATE_ENCRYPTION_SECONDARY_KEY= # Generated automatically by init.sh if empty

# Email Configuration (defaults to internal Mailpit)
NEXT_PRIVATE_SMTP_TRANSPORT=smtp-auth
NEXT_PRIVATE_SMTP_HOST=mailpit
NEXT_PRIVATE_SMTP_PORT=1025
NEXT_PRIVATE_SMTP_USERNAME=
NEXT_PRIVATE_SMTP_PASSWORD=
NEXT_PRIVATE_SMTP_SECURE=false
NEXT_PRIVATE_SMTP_FROM_NAME=Documenso
NEXT_PRIVATE_SMTP_FROM_ADDRESS=noreply@documenso.local

# Signing Configuration
NEXT_PRIVATE_SIGNING_TRANSPORT=local
NEXT_PRIVATE_SIGNING_PASSPHRASE=password
# The certificate file will be generated at ./certs/cert.p12 by init.sh

# Storage Configuration
# Options: s3, database (experimental/if supported), or local?
# Defaulting to database as per some community setups, or s3 with minio if needed.
# For now, we leave it as is or default to something simple.
# If using S3:
# NEXT_PUBLIC_UPLOAD_TRANSPORT=s3
# NEXT_PRIVATE_UPLOAD_ENDPOINT=http://minio:9000
# NEXT_PRIVATE_UPLOAD_REGION=us-east-1
# NEXT_PRIVATE_UPLOAD_BUCKET=documenso
# NEXT_PRIVATE_UPLOAD_ACCESS_KEY_ID=minioadmin
# NEXT_PRIVATE_UPLOAD_SECRET_ACCESS_KEY=minioadmin
